# PostFlow AI — WhatsApp Bot Environment Variables
# Copy this to Railway dashboard → Variables section
# DO NOT commit this file to GitHub (already in .gitignore)

# From Meta App Dashboard → WhatsApp → API Setup
META_ACCESS_TOKEN=your_meta_access_token_here
META_PHONE_NUMBER_ID=your_phone_number_id_here

# Choose any string — you'll paste this in Meta webhook settings
META_VERIFY_TOKEN=postflow_verify_2024

# From aistudio.google.com/app/apikey
GEMINI_KEY=AIza_your_gemini_key_here

# Free tier rate limits (optional — these are the defaults)
# How many AI requests each visitor can make per hour / per day
RATE_LIMIT_PER_HOUR=20
RATE_LIMIT_PER_DAY=50

# Your Vercel frontend URL (for CORS protection)
FRONTEND_URL=https://postflow-ai-iota.vercel.app

# Railway sets this automatically
PORT=3000
